# Fast Lane - Environment Configuration Example
# Copy this file to .env and update with your settings

# ============== APPLICATION ==============
ENVIRONMENT=development
DEBUG=True
APP_NAME="Fast Lane"

# ============== SERVER ==============
HOST=127.0.0.1
PORT=8000
RELOAD=True

# ============== DATABASE ==============
# SQLite (Development)
DATABASE_URL=sqlite:///./database/fast_lane.db

# PostgreSQL (Production - Uncomment and configure)
# DATABASE_URL=postgresql://user:password@localhost:5432/fast_lane_db

# Database Settings
DATABASE_ECHO=False

# ============== JWT & SECURITY ==============
# IMPORTANT: Generate a strong secret key for production!
# You can generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ============== CORS ==============
# Allowed origins (comma-separated)
# CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ============== LOGGING ==============
LOG_LEVEL=INFO
LOG_FILE=logs/fast_lane.log

# ============== GAME SETTINGS ==============
# Physics
DEFAULT_GRAVITY=9.8
MAX_WIND_SPEED=30.0

# Currency (starting values)
STARTING_COINS=0
STARTING_GEMS=0

# ============== FEATURES ==============
ENABLE_LEADERBOARD=True
ENABLE_ACHIEVEMENTS=True
ENABLE_MULTIPLAYER=False
ENABLE_ANALYTICS=True

# ============== RATE LIMITING ==============
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ============== OPTIONAL: EXTERNAL SERVICES ==============
# Add API keys for third-party services here
# STRIPE_API_KEY=your_stripe_key
# SENDGRID_API_KEY=your_sendgrid_key
# ANALYTICS_ID=your_analytics_id
